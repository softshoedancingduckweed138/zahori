{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.josesepulvedapino/zahori",
  "description": "Find the media stream behind any web page: browser-driven HLS/DASH/MP4 with learnable site profiles",
  "repository": {
    "url": "https://github.com/josesepulvedapino/zahori",
    "source": "github"
  },
  "version": "0.1.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "zahori",
      "version": "0.1.1",
      "runtimeHint": "npx",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        {
          "type": "positional",
          "value": "mcp"
        }
      ]
    }
  ]
}
